### Example environment variables for local development
# Do NOT commit sensitive values. Copy this file to `.env.development` and
# update values as needed.

# If set to `true`, the Dashboard will load built-in sample data and skip
# the assets API fetch. Useful for local development when backend or
# private registries are unavailable.
VITE_FORCE_SAMPLE_DATA=false

# Adobe IMS / Dynamic Media configuration
VITE_ADOBE_CLIENT_ID=
VITE_BUCKET=

# When true, applies Heineken-inspired demo skin + grid strip on startup (local UI demo only).
# VITE_HEINEKEN_DEMO=true
