### Example environment variables for local development
# Do NOT commit sensitive values. Copy this file to `.env.development` and
# update values as needed.

# If set to `true`, the Dashboard will load built-in sample data and skip
# the assets API fetch. Useful for local development when backend or
# private registries are unavailable.
VITE_FORCE_SAMPLE_DATA=false

# Adobe IMS / Dynamic Media configuration
VITE_ADOBE_CLIENT_ID=
VITE_BUCKET=

# When true, applies Heineken-inspired demo skin + grid strip on startup (local UI demo only).
# VITE_HEINEKEN_DEMO=true

# Portal personas (optional JWT substring envs: VITE_IMS_PERSONA_PORTAL_ADMIN_SUBSTRINGS,
# VITE_IMS_PERSONA_ORG_ADMIN_SUBSTRINGS, VITE_IMS_PERSONA_DEVELOPER_SUBSTRINGS, VITE_IMS_PERSONA_CREATIVE_SUBSTRINGS,
# VITE_IMS_PERSONA_MARKETEER_SUBSTRINGS, VITE_IMS_PERSONA_CONTENT_CREATOR_SUBSTRINGS, VITE_IMS_PERSONA_APPROVER_SUBSTRINGS,
# VITE_IMS_PERSONA_REVIEWER_SUBSTRINGS, VITE_IMS_PERSONA_EDITOR_SUBSTRINGS, VITE_IMS_PERSONA_AGENT_SUBSTRINGS).
# Legacy VITE_IMS_PERSONA_ADMIN_SUBSTRINGS still maps to org admin when ORG_ADMIN env is unset.

# Comma-separated persona ids to simulate multiple roles (e.g. org_admin,developer) when JWT does not list both.
# VITE_PORTAL_SIMULATED_ROLES=org_admin,developer

# When not `false`, IMS org admins (see VITE_IMS_ADMIN_GROUP_SUBSTRINGS) get both org_admin and developer
# personas when the token matches only one of them (typical technical admin). Set to `false` to disable.
# VITE_PORTAL_DUAL_ROLE_ORG_ADMIN_DEVELOPER=false
